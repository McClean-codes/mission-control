# ============================================================================
# Database Provider (sqlite | supabase). Default: sqlite
# WARNING: Must match NEXT_PUBLIC_DATABASE_PROVIDER
# ============================================================================
DATABASE_PROVIDER=supabase
NEXT_PUBLIC_DATABASE_PROVIDER=supabase

# ============================================================================
# Supabase Configuration (required when DATABASE_PROVIDER=supabase)
# ============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============================================================================
# Optional: Agent Dispatch Layer (Phase 4, requires DATABASE_PROVIDER=supabase)
# ============================================================================
SUPABASE_AGENT_DISPATCH=true
NEXT_PUBLIC_SUPABASE_AGENT_DISPATCH=true

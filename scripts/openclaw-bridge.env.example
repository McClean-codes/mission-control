# OpenClaw Bridge Configuration
# Copy this file to .env (or set env vars in systemd service) before running the bridge

# Supabase project credentials
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenClaw gateway location (default: http://localhost:18789)
OPENCLAW_GATEWAY_URL=http://localhost:18789

# Comma-separated list of agent names to track
AGENT_IDS=sherlock,edison,nikola,newton,scout

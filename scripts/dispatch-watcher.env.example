# Map agent IDs to session keys (agent_id=session_key, comma-separated)
# Session keys are available from the gateway: GET /sessions or sessions_list tool
# Example: sherlock=agent:main:main,nikola=agent:nikola:main
AGENT_SESSION_KEYS=sherlock=agent:main:main
